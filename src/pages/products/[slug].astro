---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import CTAButton from '../../components/CTAButton.astro';

// 1. GENERATE PATHS
export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

// 2. GET DATA
const { product } = Astro.props;
const { Content } = await product.render();
const { title, id, category, image, standards, description, specifications, seo } = product.data;

// --- A. LOGIC GAMBAR AMAN (FALLBACK) ---
// Agar tidak error saat upload massal tanpa gambar
const imageSrc = image && image.trim() !== "" 
  ? image 
  : "https://placehold.co/600x600/e2e8f0/1e293b?text=No+Image";

// --- B. LOGIC SEO PRIORITAS ---
const seoData = seo || {};

// 1. Title: Custom Meta Title > Format Default
const metaTitle = seoData.metaTitle || `Jual ${title} - Spesifikasi & Harga`;

// 2. Description: Custom Meta Desc > Deskripsi Produk
const metaDesc = seoData.metaDescription || description;

// 3. H1 Title: Custom Title > Nama Produk
const h1Title = seoData.customTitle || title;

// 4. Canonical & NoIndex
const canonicalURL = seoData.canonicalUrl || new URL(Astro.url.pathname, Astro.site).toString();
const isNoIndex = seoData.noIndex || false;

// --- C. RELATED PRODUCTS ---
const allProducts = await getCollection('products');
const relatedProducts = allProducts
  .filter(p => p.data.category === category && p.slug !== product.slug)
  .slice(0, 4);

// --- D. SCHEMA MARKUP ---
const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": h1Title,
  "image": imageSrc, // Pakai imageSrc yang aman
  "description": metaDesc,
  "sku": id,
  "brand": { "@type": "Brand", "name": "CV. Sawarga Teknik" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "price": "0", // 0 menandakan Call for Price
    "priceCurrency": "IDR",
    "url": canonicalURL
  }
};
---

<Layout 
  title={metaTitle} 
  description={metaDesc}
  type="product"
  image={imageSrc}
  canonical={canonicalURL}
  noIndex={isNoIndex}
>
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} slot="head" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
      
      <div class="lg:col-span-5 lg:sticky lg:top-24 h-fit">
        
        <div class="bg-white border-2 border-civil-dark shadow-hard p-1 mb-6 relative group">
            <a 
              href={`/products/${category.toLowerCase()}`}
              class="absolute top-3 left-3 z-10 bg-civil-secondary text-civil-primary text-[10px] font-black uppercase px-2 py-1 border border-civil-dark shadow-sm hover:bg-civil-primary hover:text-white transition-colors cursor-pointer"
            >
              {category}
            </a>
          
          <div class="aspect-square bg-gray-100 overflow-hidden relative border border-gray-200">
             <img 
               src={imageSrc} 
               alt={title} 
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
             />
             <div class="absolute bottom-2 right-2 opacity-50 text-[10px] font-black text-gray-400 uppercase">
               CV. Sawarga Teknik
             </div>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3 mb-6">
            <CTAButton 
                mode="wa" 
                text="Chat WhatsApp" 
                productName={title} 
                variant="primary" 
                className="w-full text-xs md:text-sm py-4" 
            />
            
            <a 
                href="#deskripsi"
                class="flex items-center justify-center gap-2 border-2 border-civil-dark bg-white text-civil-dark font-black uppercase text-xs md:text-sm hover:bg-gray-50 transition-colors shadow-[2px_2px_0px_0px_#1E293B] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-none active:shadow-none"
            >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
                Baca Deskripsi
            </a>
        </div>

        <div class="bg-gray-50 border border-gray-200 p-4 text-xs text-gray-600 space-y-2 rounded-sm mb-6 lg:mb-0">
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <span class="font-bold">Stok Tersedia (Hubungi Admin)</span>
            </div>
            <div class="flex items-center gap-2">
                <svg class="w-4 h-4 text-civil-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" /></svg>
                <span>Pembayaran Aman (Invoice/PO)</span>
            </div>
        </div>

      </div>

      <div class="lg:col-span-7">
        
        <div class="mb-8">
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-civil-primary uppercase leading-none mb-4">
                {h1Title}
            </h1>
            
            <div class="flex flex-wrap items-center gap-3 mb-6">
                <span class="bg-civil-dark text-white px-3 py-1 text-sm font-mono font-bold rounded-sm">
                    ID: {id}
                </span>
                
                {standards && standards.length > 0 && standards.map(std => (
                    <span class="border border-civil-secondary text-civil-primary px-3 py-1 text-xs font-bold uppercase bg-yellow-50/50">
                        {std}
                    </span>
                ))}
            </div>

            {description && (
              <p class="text-lg text-gray-600 leading-relaxed border-l-4 border-civil-secondary pl-4">
                  {description}
              </p>
            )}
        </div>

{specifications && specifications.length > 0 && (
            <div class="mb-10">
                <h2 class="text-3xl font-black text-civil-primary uppercase mb-4 flex items-center gap-2">
                    <span class="w-6 h-1 bg-civil-secondary"></span> Spesifikasi Teknis
                </h2>
                <div class="overflow-hidden border-2 border-gray-100 rounded-sm">
                    <table class="w-full text-sm">
                        <tbody class="divide-y divide-gray-100">
                           {/* --- MULAI BAGIAN YG DIGANTI --- */}
                            {specifications.map((spec, index) => (
                                <tr class={index % 2 === 0 ? "bg-white" : "bg-gray-50"}>
                                    <td class="px-5 py-3 font-bold text-civil-dark w-1/3 align-top">{spec.key}</td>
                                    <td class="px-5 py-3 text-gray-600 font-mono align-top">{spec.value}</td>
                                </tr>
                            ))}
                           {/* --- SELESAI BAGIAN YG DIGANTI --- */}
                        </tbody>
                    </table>
                </div>
            </div>
        )}

        <div id="deskripsi" class="scroll-mt-28">
            <h2 class="text-3xl font-black text-civil-primary uppercase mb-4 flex items-center gap-2">
                <span class="w-6 h-1 bg-civil-secondary"></span> Detail Lengkap
            </h2>
            
            <article class="prose prose-slate max-w-none prose-headings:font-black prose-headings:text-civil-dark prose-p:text-gray-600 prose-li:text-gray-600 prose-img:border-2 prose-img:border-gray-200 prose-img:rounded-sm">
                <Content />
            </article>
        </div>

        <div class="mt-12 bg-civil-primary p-8 md:p-10 text-center rounded-sm border-t-4 border-civil-secondary shadow-2xl relative overflow-hidden">
              <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#FFC107 1px, transparent 1px); background-size: 20px 20px;"></div>
              
              <div class="relative z-10">
                  <h3 class="text-2xl md:text-3xl font-black text-white uppercase mb-4">
                    Tertarik dengan Alat Ini?
                  </h3>
                  <p class="text-gray-300 mb-8 max-w-xl mx-auto">
                    Dapatkan penawaran harga resmi (Quotation) untuk pengadaan alat <strong>{title}</strong>. Kami melayani surat dukungan tender.
                  </p>
                  
                  <div class="flex justify-center">
                     <CTAButton 
                        mode="modal" 
                        text="Minta Penawaran Harga" 
                        productName={title} 
                        variant="secondary" 
                        className="px-10 py-4 text-base md:text-lg w-full md:w-auto shadow-none hover:translate-x-0 hover:translate-y-0 hover:scale-105" 
                     />
                  </div>
                  
                  <p class="text-[10px] text-gray-400 mt-4 uppercase tracking-widest">
                    Respon Cepat 1 Jam (Jam Kerja)
                  </p>
              </div>
        </div>

      </div>
    </div>

    {relatedProducts.length > 0 && (
      <div class="mt-20 pt-10 border-t-2 border-gray-100">
        <h2 class="text-2xl font-black text-civil-primary uppercase mb-8">Produk Sejenis Lainnya</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {relatedProducts.map((p) => (
            <ProductCard product={p} />
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>