---
import Layout from '../../../layouts/Layout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import Pagination from '../../../components/Pagination.astro';
import { getCollection } from 'astro:content';

// 1. SETUP PAGINATION PER KATEGORI
export async function getStaticPaths({ paginate }) {
  const allProducts = await getCollection('products');
  
  // Definisi Kategori
  const categories = [
    { slug: "aspal", name: "Alat Lab Aspal" },
    { slug: "beton", name: "Alat Lab Beton" },
    { slug: "tanah", name: "Alat Lab Tanah" },
    { slug: "batuan", name: "Alat Lab Batuan" },
    { slug: "semen", name: "Alat Lab Semen" },
    { slug: "pertambangan", name: "Pertambangan" },
    { slug: "umum", name: "Alat Umum" },
  ];

  // Generate paths untuk setiap kategori + paginationnya
  return categories.flatMap(({ slug, name }) => {
    const filteredProducts = allProducts.filter(p => 
        p.data.category.toLowerCase() === name.replace("Alat Lab ", "").toLowerCase() || 
        p.data.category.toLowerCase() === slug
    );
    
    // Urutkan
    const sortedFiltered = filteredProducts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

    // Fungsi paginate akan otomatis membuat route /products/beton/1, /products/beton/2, dst.
    return paginate(sortedFiltered, {
      params: { category: slug },
      props: { name },
      pageSize: 12
    });
  });
}

const { page, name } = Astro.props;
const { category } = Astro.params;
const products = page.data;

// Sidebar Config
const sidebarLinks = [
  { name: "Semua Produk", slug: "/products", active: false },
  { name: "Alat Lab Aspal", slug: "/products/aspal", active: category === 'aspal' },
  { name: "Alat Lab Beton", slug: "/products/beton", active: category === 'beton' },
  { name: "Alat Lab Tanah", slug: "/products/tanah", active: category === 'tanah' },
  { name: "Alat Lab Batuan", slug: "/products/batuan", active: category === 'batuan' },
  { name: "Alat Lab Semen", slug: "/products/semen", active: category === 'semen' },
  { name: "Pertambangan", slug: "/products/pertambangan", active: category === 'pertambangan' },
  { name: "Alat Umum", slug: "/products/umum", active: category === 'umum' },
];
---

<Layout 
  title={`Jual ${name} - Halaman ${page.currentPage}`} 
  description={`Katalog ${name} terlengkap standar SNI/ASTM. Halaman ${page.currentPage}.`}
>

  <div class="bg-white border-b border-gray-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 mb-2 text-xs font-bold uppercase text-civil-secondary tracking-widest">
        <span>Kategori</span>
        <span class="w-8 h-0.5 bg-civil-secondary"></span>
      </div>
      <h1 class="text-3xl md:text-4xl font-black text-civil-primary uppercase mb-2">
        {name}
      </h1>
      <p class="text-gray-600 max-w-2xl">
        Halaman {page.currentPage}. Menampilkan produk untuk kategori <strong>{name}</strong>.
      </p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      <aside class="hidden lg:block lg:col-span-1">
        <div class="sticky top-24 space-y-8">
          <div class="bg-white border-2 border-civil-dark shadow-hard">
            <div class="bg-civil-primary text-white p-3 font-bold uppercase text-sm tracking-wider border-b-2 border-civil-dark">
              Filter Kategori
            </div>
            <nav class="flex flex-col p-2">
              {sidebarLinks.map((link) => (
                <a 
                  href={link.slug} 
                  class={`px-3 py-2 text-sm font-bold border-b border-gray-100 last:border-0 hover:text-civil-primary transition-colors ${link.active ? 'text-civil-primary bg-civil-secondary/20 border-l-4 border-civil-secondary' : 'text-gray-600 border-l-4 border-transparent hover:border-gray-300'}`}
                >
                  {link.name}
                </a>
              ))}
            </nav>
          </div>
          
          <div class="bg-civil-secondary p-6 text-center border-2 border-civil-dark">
            <h3 class="font-black text-civil-primary uppercase mb-2">Butuh Bantuan?</h3>
            <p class="text-xs text-civil-dark mb-4">Konsultasikan kebutuhan alat {name} Anda.</p>
            <a href="https://wa.me/6281234567890" target="_blank" class="block w-full bg-white border-2 border-civil-dark py-2 text-xs font-bold uppercase hover:bg-civil-primary hover:text-white transition-colors">
              Chat Sales
            </a>
          </div>
        </div>
      </aside>

      <div class="lg:hidden col-span-1 mb-6">
         <label for="cat-filter" class="block text-xs font-bold uppercase text-gray-500 mb-2">Pilih Kategori:</label>
         <div class="relative w-full">
            <select 
              id="cat-filter"
              onchange="window.location.href=this.value"
              class="appearance-none w-full border-2 border-civil-dark pl-4 pr-12 py-3 font-bold text-civil-dark bg-white rounded-none focus:outline-none focus:ring-2 focus:ring-civil-secondary focus:border-civil-primary shadow-sm"
            >
              {sidebarLinks.map((link) => (
                <option value={link.slug} selected={link.active}>{link.name}</option>
              ))}
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-civil-dark bg-civil-secondary border-l-2 border-civil-dark">
                <svg class="h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
         </div>
      </div>

      <div class="lg:col-span-3">
        {products.length > 0 ? (
          <>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
              {products.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
            <Pagination page={page} />
          </>
        ) : (
          <div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded p-12 text-center">
            <h3 class="text-lg font-bold text-gray-500">Stok Kosong</h3>
            <p class="text-sm text-gray-400">Tidak ada produk ditemukan di kategori ini.</p>
            <a href="/products" class="inline-block mt-4 text-civil-primary font-bold hover:underline">Lihat Semua Produk &rarr;</a>
          </div>
        )}
      </div>

    </div>
  </div>
</Layout>