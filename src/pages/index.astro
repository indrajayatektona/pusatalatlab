---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import CTAButton from '../components/CTAButton.astro';
import { getCollection } from 'astro:content';

// --- 1. CONFIGURATION (Edit Data Disini) ---
const CONFIG = {
  // SEO METADATA
  seoTitle: "Pusat Alat Laboratorium Teknik Sipil Terlengkap",
  seoDescription: "Pusat jual alat laboratorium teknik sipil, beton, aspal, tanah, dan batuan standar SNI/ASTM. Distributor garansi resmi di Indonesia.",
  // Ganti src iframe ini dengan embed map lokasi aslimu
  mapEmbed: "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.9148161187377!2d107.5633199!3d-6.9007906!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e68e5dac448a897%3A0x175b1b26bda5aadc!2sJl.%20Jend.%20H.%20Amir%20Machmud%20No.111%2F115%2C%20Cibeureum%2C%20Kec.%20Andir%2C%20Kota%20Cimahi%2C%20Jawa%20Barat%2040535!5e0!3m2!1sid!2sid!4v1770237882502!5m2!1sid!2sid",
  address: "Jl.Jend Amir Machmud No 111/115 , Cibeureum , Cimahi Selatan Jawa Barat.",
  phone: "+6287-893-030-300",
  email: "admin@pusatalatlabsipil.com",
  heroImage: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=2600&auto=format&fit=crop" // Foto background Hero
};

// --- 2. DATA FETCHING ---
const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter(p => p.data.featured).slice(0, 4);
const allPosts = await getCollection('blog');
const latestPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);

// Fallback Data (Jika CMS kosong)
const dummyProducts = featuredProducts.length > 0 ? featuredProducts : [
  { slug: 'hand-bor-test-set/', data: { title: "Hand Bor Test Set", id: "SO-110 A", category: "Tanah", image: "https://pusatalatlabsipil.com/images/products/hand-bor-test-set/image.jpg", standards: ["ASTM D-1452"] } },
  { slug: 'compaction-test-set/', data: { title: "Compaction Test Seet", id: "CO-325", category: "Beton", image: "https://pusatalatlabsipil.com/images/products/compaction-test-set/image.jpg", standards: ["ASTM D-698"] } },
  { slug: 'cbr-lapangan/', data: { title: "CBR Lapangan", id: "SO-260", category: "Tanah", image: "https://pusatalatlabsipil.com/images/products/cbr-lapangan/image.jpg", standards: ["ASTM D-4429"] } },
  { slug: 'direct-shear-test-set/', data: { title: "Direct Shear Test Set", id: "SO-525", category: "Tanah", image: "https://pusatalatlabsipil.com/images/products/direct-shear-test-set/image.jpg", standards: ["ASTM D-3080"] } },
];

const categories = [
  { 
    name: "Alat Lab Aspal", 
    slug: "aspal", 
    icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" 
  },
  { 
    name: "Alat Lab Batuan", 
    slug: "batuan", 
    icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" // (Icon kubus/solid)
  },
  { 
    name: "Alat Lab Beton", 
    slug: "beton", 
    icon: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" // (Icon silinder)
  },
  { 
    name: "Pertambangan", 
    slug: "pertambangan", 
    icon: "M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" // (Icon tas/kit lapangan)
  },
  { 
    name: "Alat Lab Semen", 
    slug: "semen", 
    icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" // (Icon tumpukan/material)
  },
  { 
    name: "Alat Lab Tanah", 
    slug: "tanah", 
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" 
  },
  { 
    name: "Alat Umum", 
    slug: "umum",
	hide: true,
    icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" // (Icon Gear)
  }
];

const faqs = [
  { q: "Apakah alat sudah terkalibrasi KAN?", a: "Ya, sebagian besar alat ukur kami seperti Compression Machine dan Proving Ring sudah termasuk sertifikat Kalibrasi KAN (ISO 17025)." },
  { q: "Berapa lama garansi produk?", a: "Kami memberikan garansi service 12 bulan dan ketersediaan sparepart terjamin untuk alat-alat manufaktur lokal." },
  { q: "Apakah bisa kirim ke luar pulau?", a: "Tentu. Kami bekerja sama dengan ekspedisi kargo darat, laut, dan udara untuk pengiriman aman ke seluruh Indonesia dengan packing kayu standar ekspor." },
  { q: "Bagaimana cara meminta surat dukungan tender?", a: "Silakan hubungi tim sales kami via WhatsApp atau email dengan melampirkan detail paket pekerjaan. Kami siap menerbitkan surat dukungan resmi." }
];
---

<Layout 
  title={CONFIG.seoTitle} 
  description={CONFIG.seoDescription} 
  isFullWidth={true}
>

  <section class="relative h-[85vh] min-h-[600px] w-full flex items-center border-b-4 border-civil-secondary bg-civil-dark">
    <div class="absolute inset-0 z-0">
      <img src={CONFIG.heroImage} alt="Gudang Alat Laboratorium Teknik Sipil" class="w-full h-full object-cover opacity-60" />
      <div class="absolute inset-0 bg-gradient-to-r from-civil-primary via-civil-primary/90 to-transparent"></div>
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur border border-white/20 px-3 py-1 rounded-sm mb-6 shadow-sm">
          <span class="w-2 h-2 bg-civil-secondary rounded-full animate-pulse"></span>
          <span class="text-[10px] font-black tracking-[0.2em] text-white uppercase">Mitra BUMN & Universitas</span>
        </div>

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight uppercase mb-6 drop-shadow-lg">
          Distributor Alat <br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-civil-secondary to-yellow-100">Lab Teknik Sipil</span><br/>
          Terlengkap
        </h1>

        <p class="text-lg md:text-xl text-gray-300 mb-8 max-w-xl border-l-4 border-civil-secondary pl-6 leading-relaxed">
          Menyediakan 100+ produk alat uji <strong>Beton, Aspal, Tanah, & Batuan</strong> standar SNI/ASTM/AASHTO. Ready stock dengan garansi resmi.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <CTAButton mode="modal" text="Lihat Katalog Produk" variant="secondary" className="shadow-hard border-white w-full sm:w-auto" />
          <CTAButton mode="wa" text="Konsultasi Gratis (WA)" variant="primary" className="border-white w-full sm:w-auto" />
        </div>

        <div class="mt-8 flex flex-wrap gap-6 text-xs font-bold text-gray-400 uppercase tracking-widest">
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-civil-secondary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> ISO 9001:2015</span>
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-civil-secondary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Kalibrasi KAN</span>
          <span class="flex items-center gap-2"><svg class="w-4 h-4 text-civil-secondary" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg> Kirim Se-Indonesia</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-gray-50 border-y border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-bold text-gray-400 uppercase tracking-[0.2em] mb-8">Dipercaya Oleh Instansi & Perusahaan</p>
      <div class="grid grid-cols-2 md:grid-cols-6 gap-8 items-center opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500">
        {[1, 2, 3, 4, 5, 6].map((i) => (
           <img src={`https://placehold.co/200x100/e5e7eb/6b7280?text=CLIENT+${i}`} alt={`Logo Client ${i}`} class="h-12 w-full object-contain mix-blend-multiply" />
        ))}
      </div>
    </div>
  </section>

<section class="py-20 bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-black text-civil-primary uppercase">Kategori Produk</h2>
        <p class="text-gray-600 mt-2">Pilih kategori alat berdasarkan kebutuhan pengujian proyek.</p>
        <div class="w-20 h-1 bg-civil-secondary mx-auto mt-4"></div>
      </div>

      <div class="flex flex-wrap justify-center gap-6">
        {categories.filter(c => !c.hide).map((cat) => (
          <a href={`/products/${cat.slug}`} class="group flex flex-col items-center justify-center p-6 bg-gray-50 border-2 border-transparent hover:border-civil-primary hover:shadow-hard transition-all duration-300 rounded-sm w-[45%] md:w-[30%] lg:w-[13%] min-w-[140px]">
            <div class="w-12 h-12 mb-4 text-civil-dark group-hover:text-civil-primary transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={cat.icon} />
              </svg>
            </div>
            <h3 class="text-xs font-black text-gray-700 uppercase text-center group-hover:text-civil-primary tracking-wide leading-tight">{cat.name}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-civil-dark text-white border-y-4 border-civil-secondary">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-civil-secondary flex items-center justify-center text-civil-primary font-black shadow-[4px_4px_0px_0px_white]">01</div>
          <div>
            <h3 class="text-lg font-black uppercase text-civil-secondary mb-2">Standar SNI & ASTM</h3>
            <p class="text-sm text-gray-300 leading-relaxed">Seluruh alat diproduksi mengacu pada standar internasional dan nasional untuk validitas data uji lab yang akurat.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-civil-secondary flex items-center justify-center text-civil-primary font-black shadow-[4px_4px_0px_0px_white]">02</div>
          <div>
            <h3 class="text-lg font-black uppercase text-civil-secondary mb-2">Jaminan Garansi</h3>
            <p class="text-sm text-gray-300 leading-relaxed">Garansi service 1 tahun dan ketersediaan sparepart jangka panjang untuk melindungi investasi alat Anda.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-civil-secondary flex items-center justify-center text-civil-primary font-black shadow-[4px_4px_0px_0px_white]">03</div>
          <div>
            <h3 class="text-lg font-black uppercase text-civil-secondary mb-2">Support Tender</h3>
            <p class="text-sm text-gray-300 leading-relaxed">Kami siap membantu administrasi teknis seperti Surat Dukungan, Brosur Asli, dan Jaminan Purna Jual untuk lelang.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
        <div>
           <span class="text-civil-secondary font-bold tracking-[0.2em] text-xs uppercase">Rekomendasi Ahli</span>
           <h2 class="text-3xl md:text-4xl font-black text-civil-primary uppercase mt-1">Produk Terpopuler</h2>
        </div>
        <a href="/products" class="inline-flex items-center gap-2 font-bold text-civil-dark border-b-2 border-civil-secondary pb-1 hover:text-civil-primary hover:border-civil-primary transition-colors">
          Lihat Katalog Lengkap <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {dummyProducts.map((item: any) => (
          <ProductCard product={item.data ? item : { data: item, slug: item.slug }} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-2xl md:text-3xl font-black text-civil-primary uppercase">Proses Pengadaan Mudah</h2>
            <p class="text-gray-600 mt-2">Kami menyederhanakan proses pengadaan alat lab untuk instansi & swasta.</p>
        </div>

        <div class="relative grid grid-cols-1 md:grid-cols-4 gap-8">
            <div class="hidden md:block absolute top-8 left-0 w-full h-1 bg-gray-100 -z-10"></div>

            <div class="relative bg-white p-4 text-center group">
                <div class="w-16 h-16 mx-auto bg-civil-dark text-white rounded-full flex items-center justify-center text-xl font-black border-4 border-white shadow-hard mb-4 group-hover:bg-civil-secondary group-hover:text-civil-primary transition-colors">1</div>
                <h3 class="font-bold text-civil-primary uppercase mb-2">Pilih Produk</h3>
                <p class="text-sm text-gray-500">Cari alat melalui katalog website atau konsultasi dengan sales kami via WA.</p>
            </div>

            <div class="relative bg-white p-4 text-center group">
                <div class="w-16 h-16 mx-auto bg-civil-dark text-white rounded-full flex items-center justify-center text-xl font-black border-4 border-white shadow-hard mb-4 group-hover:bg-civil-secondary group-hover:text-civil-primary transition-colors">2</div>
                <h3 class="font-bold text-civil-primary uppercase mb-2">Minta Penawaran</h3>
                <p class="text-sm text-gray-500">Kami kirimkan Surat Penawaran Harga (Quotation) resmi & spesifikasi teknis.</p>
            </div>

            <div class="relative bg-white p-4 text-center group">
                <div class="w-16 h-16 mx-auto bg-civil-dark text-white rounded-full flex items-center justify-center text-xl font-black border-4 border-white shadow-hard mb-4 group-hover:bg-civil-secondary group-hover:text-civil-primary transition-colors">3</div>
                <h3 class="font-bold text-civil-primary uppercase mb-2">PO & Pembayaran</h3>
                <p class="text-sm text-gray-500">Terbitkan Purchase Order (PO) dan lakukan pembayaran sesuai termin yang disepakati.</p>
            </div>

            <div class="relative bg-white p-4 text-center group">
                <div class="w-16 h-16 mx-auto bg-civil-dark text-white rounded-full flex items-center justify-center text-xl font-black border-4 border-white shadow-hard mb-4 group-hover:bg-civil-secondary group-hover:text-civil-primary transition-colors">4</div>
                <h3 class="font-bold text-civil-primary uppercase mb-2">Packing & Kirim</h3>
                <p class="text-sm text-gray-500">Barang dikalibrasi, dipacking kayu aman, dan dikirim ke lokasi proyek Anda.</p>
            </div>
        </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        
        <div class="prose prose-lg prose-headings:font-black prose-headings:text-civil-primary prose-a:text-civil-secondary">
          <span class="text-civil-secondary font-bold text-xs tracking-widest uppercase block mb-2">Tentang Perusahaan</span>
          <h2 class="mt-0 mb-6 text-4xl leading-tight">Mitra Terpercaya Laboratorium Sipil Indonesia</h2>
          <p class="text-gray-600 text-base leading-relaxed">
            <strong>CV. Sawarga Teknik</strong> adalah perusahaan manufaktur dan distributor alat uji teknik sipil yang berfokus pada kualitas dan presisi. Sejak berdiri, kami telah dipercaya oleh ratusan instansi pemerintah, BUMN, dan kontraktor swasta untuk memenuhi kebutuhan alat laboratorium tanah, beton, aspal, dan batuan.
          </p>
          <p class="text-gray-600 text-base leading-relaxed">
            Komitmen kami adalah menyediakan alat dengan durabilitas tinggi yang sesuai dengan standar pengujian (SNI/ASTM) untuk memastikan keamanan infrastruktur Indonesia.
          </p>
          
          <div class="not-prose mt-8 overflow-hidden border-2 border-gray-100 rounded-sm">
            <table class="min-w-full text-sm text-left">
              <thead class="bg-civil-dark text-white uppercase font-bold">
                <tr>
                  <th class="px-6 py-3">Cakupan Layanan</th>
                  <th class="px-6 py-3">Detail</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="bg-white hover:bg-gray-50">
                  <td class="px-6 py-3 font-bold text-civil-dark">Klien</td>
                  <td class="px-6 py-3 text-gray-600">Dinas PU, Kontraktor, Konsultan, Universitas</td>
                </tr>
                <tr class="bg-gray-50 hover:bg-gray-100">
                  <td class="px-6 py-3 font-bold text-civil-dark">Area Kirim</td>
                  <td class="px-6 py-3 text-gray-600">Seluruh Indonesia (Sabang - Merauke)</td>
                </tr>
                <tr class="bg-white hover:bg-gray-50">
                  <td class="px-6 py-3 font-bold text-civil-dark">Legalitas</td>
                  <td class="px-6 py-3 text-gray-600">PKP (Faktur Pajak), NIB, ISO 9001</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -top-4 -left-4 w-full h-full border-4 border-civil-secondary z-0"></div>
          <img src="https://pusatalatlabsipil.com/images/alat-laboratorium-teknik-sipil.webp" alt="Teknisi Laboratorium Sipil Sedang Bekerja" class="relative z-10 w-full h-auto shadow-2xl grayscale hover:grayscale-0 transition-all duration-500" />
          
          <div class="absolute -bottom-6 -right-6 bg-civil-primary text-white p-6 border-2 border-white shadow-hard z-20 hidden md:block">
            <p class="text-3xl font-black text-civil-secondary">10+</p>
            <p class="text-xs font-bold uppercase">Tahun Pengalaman</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
         <h2 class="text-2xl md:text-3xl font-black text-civil-primary uppercase">Wawasan Teknik</h2>
         <a href="/blog" class="px-4 py-2 bg-civil-dark text-white text-xs font-bold uppercase hover:bg-civil-secondary hover:text-civil-primary transition-colors">
            Lihat Semua Artikel
         </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestPosts.length > 0 ? latestPosts.map(post => (
          <article class="group bg-white border border-gray-200 hover:border-civil-primary hover:shadow-hard transition-all duration-300">
            <a href={`/blog/${post.slug}`}>
              <div class="aspect-video bg-gray-100 overflow-hidden relative">
                 <img src={post.data.image || "https://placehold.co/600x400"} alt={post.data.title} class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-700" />
                 <div class="absolute top-0 right-0 bg-civil-secondary text-civil-primary text-[10px] font-black px-2 py-1 uppercase">
                    Terbaru
                 </div>
              </div>
              <div class="p-6">
                <h3 class="text-lg font-bold text-civil-primary leading-tight mb-2 line-clamp-2 group-hover:text-civil-secondary transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-sm text-gray-500 line-clamp-3 mb-4">
                  {post.data.description}
                </p>
                <span class="text-xs font-bold text-civil-dark underline decoration-2 underline-offset-4">Baca Artikel →</span>
              </div>
            </a>
          </article>
        )) : (
          <div class="col-span-3 py-12 text-center border-2 border-dashed border-gray-200 rounded text-gray-400">
            <p>Artikel sedang disiapkan.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50 border-t border-gray-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-2xl md:text-3xl font-black text-civil-primary uppercase">Pertanyaan Umum (FAQ)</h2>
            <p class="text-gray-600 mt-2">Informasi yang sering ditanyakan oleh pelanggan kami.</p>
        </div>

        <div class="space-y-4">
            {faqs.map((item) => (
                <details class="group bg-white border-2 border-transparent open:border-civil-secondary shadow-sm open:shadow-md transition-all rounded-sm overflow-hidden">
                    <summary class="flex justify-between items-center font-bold cursor-pointer list-none p-5 text-civil-dark hover:bg-gray-50">
                        <span>{item.q}</span>
                        <span class="transition group-open:rotate-180">
                            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                        </span>
                    </summary>
                    <div class="text-gray-600 px-5 pb-5 text-sm leading-relaxed border-t border-gray-100 pt-3">
                        {item.a}
                    </div>
                </details>
            ))}
        </div>
    </div>
  </section>

<section class="py-20 bg-civil-primary border-t-4 border-civil-secondary">
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="grid grid-cols-1 lg:grid-cols-12 shadow-2xl border-2 border-civil-secondary bg-civil-dark">
          
          <div class="lg:col-span-4 text-white p-8 md:p-10 flex flex-col justify-center relative z-10">
              <span class="text-civil-secondary font-bold text-xs tracking-widest uppercase mb-2">Lokasi Fisik</span>
              <h2 class="text-2xl md:text-3xl font-black text-white uppercase mb-6">Kunjungi Workshop</h2>
              
              <div class="space-y-6 border-l-2 border-white/20 pl-6">
                  <div>
                      <h3 class="text-white font-bold uppercase text-xs mb-1">Alamat</h3>
                      <p class="text-gray-300 text-sm leading-relaxed">{CONFIG.address}</p>
                  </div>
                  <div>
                      <h3 class="text-white font-bold uppercase text-xs mb-1">Kontak</h3>
                      <p class="text-gray-300 text-sm">{CONFIG.phone}</p>
                      <p class="text-gray-300 text-sm">{CONFIG.email}</p>
                  </div>
                  <div>
                      <h3 class="text-white font-bold uppercase text-xs mb-1">Jam Operasional</h3>
                      <p class="text-gray-300 text-sm">Senin - Jumat: 08.00 - 17.00 WIB</p>
                  </div>
              </div>

              <div class="mt-8">
                  <a href={CONFIG.mapEmbed} target="_blank" class="inline-flex items-center justify-center w-full gap-2 border-2 border-civil-secondary text-civil-secondary px-6 py-3 text-sm font-bold uppercase hover:bg-civil-secondary hover:text-civil-primary transition-colors">
                      Buka Google Maps <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
              </div>
          </div>

          <div class="lg:col-span-8 bg-gray-200 min-h-[400px] relative group border-l-0 lg:border-l-4 border-civil-secondary">
              <iframe 
                  src={CONFIG.mapEmbed}
                  width="100%" 
                  height="100%" 
                  style="border:0;" 
                  allowfullscreen="" 
                  loading="lazy" 
                  referrerpolicy="no-referrer-when-downgrade"
                  class="absolute inset-0 w-full h-full grayscale group-hover:grayscale-0 transition-all duration-700"
              ></iframe>
          </div>

      </div>
    </div>
  </section>

  <section class="py-24 bg-white text-center">
    <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-4xl md:text-5xl font-black text-civil-primary uppercase mb-6 leading-none">
            Siap Melengkapi <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-civil-primary to-civil-secondary">Laboratorium Anda?</span>
        </h2>
        <p class="text-lg text-gray-600 mb-10 max-w-2xl mx-auto">
            Dapatkan penawaran harga terbaik (Quotation) untuk pengadaan alat lab hari ini juga. Respon cepat di jam kerja.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-6">
            <CTAButton mode="wa" text="Chat Sales Sekarang" variant="primary" className="px-10 py-4 text-lg w-full sm:w-auto" />
            <CTAButton mode="modal" text="Minta Penawaran Resmi" variant="secondary" className="px-10 py-4 text-lg w-full sm:w-auto" />
        </div>
    </div>
  </section>
  <section class="py-20 bg-civil-secondary relative overflow-hidden">
      <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, #000 0, #000 1px, transparent 0, transparent 50%); background-size: 10px 10px;"></div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="bg-civil-primary rounded-sm shadow-2xl overflow-hidden md:flex items-center">
              
              <div class="md:w-1/3 h-64 md:h-auto relative bg-gray-800">
                  <img src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?q=80&w=2670&auto=format&fit=crop" alt="Cover Katalog Alat Sipil" class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay" />
                  <div class="absolute inset-0 flex items-center justify-center">
                      <div class="text-center p-6 border-4 border-white/20 m-6">
                          <span class="text-civil-secondary font-black text-4xl block mb-1">2026</span>
                          <span class="text-white font-bold uppercase tracking-widest text-sm">Product Catalog</span>
                      </div>
                  </div>
              </div>

              <div class="md:w-2/3 p-10 md:p-12 text-white">
                  <h2 class="text-3xl font-black text-white uppercase mb-4 leading-tight">Butuh Referensi Spesifikasi Lengkap?</h2>
                  <p class="text-gray-300 text-lg mb-8 leading-relaxed">
                      Download E-Catalog terbaru kami berisi 100+ alat uji sipil lengkap dengan data teknis, dimensi, dan standar rujukan (ASTM/SNI) untuk keperluan penyusunan RAB atau Tender.
                  </p>
                  
                  <div class="flex flex-col sm:flex-row gap-4">
                      <button onclick="window.open('https://wa.me/+6287893030300?text=Halo%20Admin,%20saya%20mau%20request%20PDF%20Katalog%20Alat%20Sipil', '_blank')" class="inline-flex items-center justify-center gap-2 bg-civil-secondary text-civil-primary px-8 py-4 font-black uppercase hover:bg-white transition-colors shadow-[4px_4px_0px_0px_rgba(0,0,0,0.3)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none">
                          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                          Download PDF (15 MB)
                      </button>
                      <span class="text-xs text-gray-400 self-center">Updated: Januari 2026</span>
                  </div>
              </div>

          </div>
      </div>
  </section>

</Layout>