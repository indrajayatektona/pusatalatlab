---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Halaman Tidak Ditemukan" description="Maaf, halaman yang Anda cari tidak tersedia." noIndex={true}>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4 py-16">
    
    <div class="relative mb-8">
      <h1 class="text-9xl font-black text-gray-100 select-none">404</h1>
      <div class="absolute inset-0 flex items-center justify-center">
        <svg class="w-24 h-24 text-civil-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
    </div>

    <h2 class="text-2xl md:text-3xl font-black text-civil-primary mb-4 uppercase">
      Halaman Hilang dari Radar
    </h2>
    
    <p class="text-gray-600 max-w-md mx-auto mb-8">
      Sepertinya halaman yang Anda cari sudah dipindahkan atau tidak pernah ada. Silakan kembali ke katalog alat.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" class="px-6 py-3 bg-civil-primary text-white font-bold border-2 border-civil-dark shadow-hard hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
        Kembali ke Beranda
      </a>
      <a href="/products" class="px-6 py-3 bg-white text-civil-dark font-bold border-2 border-civil-dark shadow-hard hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
        Lihat Semua Produk
      </a>
    </div>

  </div>
</Layout>