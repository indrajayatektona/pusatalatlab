---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';

// 1. Generate Static Paths
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.PROD ? data.status !== 'draft' : true;
  });

  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// --- LOGIC AUTHOR ---
const authorData = await getEntry('authors', post.data.author.id);
const author = authorData ? authorData.data : { 
  name: 'Admin Technical', 
  role: 'Administrator',
  avatar: null,
  socials: {}
};
const { Content: AuthorBio } = authorData ? await authorData.render() : { Content: null };

// --- LOGIC SEO (BARU) ---
// Kita ambil object SEO, atau object kosong jika belum diisi
const seo = post.data.seo || {};

// 1. Title: Pakai Meta Title custom, kalau kosong pakai Judul Post
const metaTitle = seo.metaTitle || post.data.title;

// 2. Description: Pakai Meta Desc custom, kalau kosong pakai Ringkasan Post
const metaDesc = seo.metaDescription || post.data.description;

// 3. H1 Title: Pakai Custom Title, kalau kosong pakai Judul Post
const h1Title = seo.customTitle || post.data.title;

// 4. Canonical: Pakai custom URL, kalau kosong pakai URL halaman ini
const canonicalURL = seo.canonicalUrl || new URL(Astro.url.pathname, Astro.site).toString();

// 5. No Index: Ambil dari checkbox
const isNoIndex = seo.noIndex || false;

// ---------------------------

// Format Tanggal
const formattedDate = new Date(post.data.pubDate).toLocaleDateString('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = new Date(post.data.pubDate).toISOString();

// Schema Article
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": h1Title, // Gunakan H1 Title
  "image": [
    new URL(post.data.image || '/default-og.jpg', Astro.site).toString()
  ],
  "datePublished": isoDate,
  "dateModified": isoDate,
  "author": [{
      "@type": "Person",
      "name": author.name,
      "url": Astro.site
    }],
  "publisher": {
      "@type": "Organization",
      "name": "CV. Sawarga Teknik",
      "logo": {
        "@type": "ImageObject",
        "url": new URL("/logo.png", Astro.site).toString()
      }
  },
  "description": metaDesc // Gunakan deskripsi SEO
};

const allProducts = await getCollection('products', ({ data }) => {
    return import.meta.env.PROD ? data.status !== 'draft' : true;
});
const sidebarProducts = allProducts.slice(0, 2);
---

<Layout 
  title={metaTitle} 
  description={metaDesc}
  image={post.data.image}
  type="article"
  showBreadcrumbs={true}
  canonical={canonicalURL}
  noIndex={isNoIndex} 
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <article class="lg:col-span-8">
        
        <header class="mb-10 border-b-2 border-gray-100 pb-10">
          <div class="flex flex-wrap items-center gap-4 text-xs font-bold uppercase text-gray-500 tracking-widest mb-4">
            <div class="flex gap-2">
              {post.data.tags.map(tag => (
                <a 
                  href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                  class="bg-civil-secondary text-civil-primary px-2 py-1 border border-civil-dark hover:bg-civil-primary hover:text-white transition-colors cursor-pointer"
                >
                  {tag}
                </a>
              ))}
            </div>
             <span>{formattedDate}</span>
             <span>•</span>
             <span class="text-civil-primary">Oleh {author.name}</span>
          </div>
          
          <h1 class="text-3xl md:text-5xl font-black text-civil-primary uppercase leading-tight mb-6">
            {h1Title}
          </h1>

          <div class="w-full aspect-video bg-gray-100 border-2 border-civil-dark shadow-hard overflow-hidden rounded-sm">
             <img 
               src={post.data.image} 
               alt={post.data.title} 
               class="w-full h-full object-cover"
             />
          </div>
        </header>

        <div class="prose prose-lg prose-slate max-w-none 
          prose-headings:font-black prose-headings:text-civil-primary prose-headings:uppercase
          prose-h2:border-l-4 prose-h2:border-civil-secondary prose-h2:pl-4
          prose-a:text-civil-secondary prose-a:font-bold prose-a:no-underline hover:prose-a:underline
          prose-img:rounded-sm prose-img:border-2 prose-img:border-gray-200 prose-img:shadow-lg
          prose-strong:text-civil-dark">
          
          <Content />

        </div>

        <div class="mt-12 pt-8 border-t-2 border-gray-200">
           <h4 class="text-sm font-black uppercase text-gray-400 mb-4">Bagikan Artikel:</h4>
           <div class="flex gap-2">
              <a href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' ' + Astro.url.href)}`} target="_blank" class="bg-[#25D366] text-white px-4 py-2 font-bold text-sm rounded-sm hover:opacity-90 flex items-center gap-2">
                WhatsApp
              </a>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" class="bg-[#1877F2] text-white px-4 py-2 font-bold text-sm rounded-sm hover:opacity-90 flex items-center gap-2">
                Facebook
              </a>
           </div>
        </div>

      </article>

      <aside class="lg:col-span-4 space-y-8">
        
        <div class="bg-gray-50 border-2 border-gray-200 p-6 rounded-sm">
            <div class="flex items-center gap-4 mb-4">
                {author.avatar ? (
                    <img src={author.avatar} alt={author.name} class="w-14 h-14 rounded-full border-2 border-civil-secondary object-cover shadow-sm" />
                ) : (
                    <div class="w-14 h-14 rounded-full bg-civil-dark flex items-center justify-center text-white font-bold text-xl border-2 border-civil-secondary shadow-sm">
                        {author.name.charAt(0)}
                    </div>
                )}
                
                <div>
                    <h3 class="text-sm font-black text-civil-primary uppercase leading-tight">
                       {author.name}
                    </h3>
                    <span class="text-xs text-gray-500 font-bold tracking-wide">{author.role}</span>
                </div>
            </div>
            
            <div class="text-sm text-gray-600 leading-relaxed mb-4 prose prose-sm prose-p:mb-2">
                 {AuthorBio && <AuthorBio />}
            </div>
 
            {author.socials && (
              <div class="flex gap-3 text-civil-dark pt-2 border-t border-gray-200">
                 {author.socials.linkedin && (
                     <a href={author.socials.linkedin} target="_blank" class="hover:text-civil-secondary transition-colors" aria-label="LinkedIn">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                     </a>
                 )}
                 {author.socials.instagram && (
                     <a href={author.socials.instagram} target="_blank" class="hover:text-civil-secondary transition-colors" aria-label="Instagram">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                     </a>
                 )}
                 {author.socials.facebook && (
                     <a href={author.socials.facebook} target="_blank" class="hover:text-civil-secondary transition-colors" aria-label="Facebook">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
                     </a>
                 )}
              </div>
            )}
         </div>

        <div class="bg-civil-primary text-white p-6 border-2 border-civil-dark shadow-hard relative overflow-hidden">
           <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#FFC107 1px, transparent 1px); background-size: 10px 10px;"></div>
           <h3 class="text-xl font-black uppercase text-civil-secondary mb-2 relative z-10">Butuh Alat Lab?</h3>
           <p class="text-sm text-gray-300 mb-6 relative z-10">
             Kami menyediakan alat uji tanah, beton, dan aspal standar SNI.
           </p>
           <a href="/products" class="block w-full text-center bg-civil-secondary text-civil-primary font-black uppercase py-3 text-sm hover:bg-white transition-colors relative z-10">
             Lihat Katalog
           </a>
        </div>

        <div>
           <h3 class="text-sm font-black text-civil-primary uppercase mb-4 border-b border-gray-200 pb-2">
             Produk Terkait
           </h3>
           <div class="flex flex-col gap-4">
              {sidebarProducts.map(prod => (
                 <a href={`/products/${prod.slug}`} class="group flex gap-4 items-center bg-white border border-gray-200 p-2 hover:border-civil-primary hover:shadow-md transition-all">
                    <div class="w-16 h-16 bg-gray-100 flex-shrink-0 border border-gray-200 overflow-hidden">
                       <img src={prod.data.image} class="w-full h-full object-cover group-hover:scale-110 transition-transform" />
                    </div>
                    <div>
                       <h4 class="text-xs font-bold text-civil-dark uppercase group-hover:text-civil-primary line-clamp-2">{prod.data.title}</h4>
                       <span class="text-[10px] text-gray-500">Lihat Detail &rarr;</span>
                    </div>
                 </a>
              ))}
           </div>
        </div>

      </aside>

    </div>
  </div>
</Layout>