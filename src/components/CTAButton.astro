---
import { getWALink } from '../config';

interface Props {
  mode: 'modal' | 'wa' | 'link';
  text?: string;
  productName?: string;
  variant?: 'primary' | 'secondary';
  className?: string;
  href?: string; // PERBAIKAN 1: Tambahkan href ke interface Props
}

const { 
  mode, 
  text = "Hubungi Kami", 
  productName = "General Inquiry", 
  variant = 'primary',
  className = "",
  href = "#" // PERBAIKAN 2: Destructure href dengan fallback
} = Astro.props;

// 1. BASE STYLE: Struktur utama tombol (Industrial Look)
const baseStyle = "group inline-flex items-center justify-center gap-3 px-6 py-3.5 text-sm md:text-base font-black uppercase tracking-wider transition-all duration-200 border-2 border-civil-dark cursor-pointer select-none";

// 2. SHADOW STYLE: Efek tombol timbul (Gumroad Style)
const shadowStyle = "shadow-[4px_4px_0px_0px_#1E293B] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] active:shadow-none active:translate-x-[4px] active:translate-y-[4px]";

// 3. COLOR VARIANTS
const variants = {
  primary: "bg-civil-primary text-white hover:bg-[#0a1a2e]", // Navy
  secondary: "bg-civil-secondary text-civil-primary hover:bg-[#e6ac00]", // Kuning
};

const finalClass = `${baseStyle} ${shadowStyle} ${variants[variant]} ${className}`;
---

{/* PERBAIKAN 3 & 4: Rantai ternary digabungkan agar dirender secara eksklusif (mutually exclusive) */}
{mode === 'link' ? (
  /* --- MODE BARU: DIRECT LINK --- */
  <a href={href} class={finalClass}>
    <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
    </svg>
    <span>{text}</span>
  </a>
) : mode === 'wa' ? (
  /* --- MODE 1: WHATSAPP LINK --- */
  <a 
    href={getWALink(`Halo, saya ingin info harga/spesifikasi untuk: ${productName}`)} 
    target="_blank" 
    class={finalClass}
    role="button"
  >
    <svg class="w-5 h-5 flex-shrink-0 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.374-5.03c0-5.45 4.441-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>
    <span>{text}</span>
  </a>
) : (
  /* --- MODE 2: MODAL TRIGGER --- */
  <button 
    onclick={`window.dispatchEvent(new CustomEvent('open-quote', { detail: { product: '${productName}' } }))`}
    class={finalClass}
    type="button"
  >
    <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    <span>{text}</span>
  </button>
)}