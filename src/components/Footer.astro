---
import { SITE_CONFIG, getWALink } from '../config';

const currentYear = new Date().getFullYear();

// Data Link Kategori (Bisa ditambah nanti)
const categories = [
  { name: "Alat Uji Beton", href: "/products/beton" },
  { name: "Alat Uji Aspal", href: "/products/aspal" },
  { name: "Alat Uji Tanah", href: "/products/tanah" },
  { name: "Alat Uji Batuan", href: "/products/batuan" },
  { name: "Alat Uji Semen", href: "/products/semen" },
  { name: "Pengeboran", href: "/products/pertambangan" },
];

const quickLinks = [
  { name: "Tentang Kami", href: "/about" },
  { name: "Artikel & Berita", href: "/blog" },
  { name: "Cara Pemesanan", href: "/guide" },
  { name: "Hubungi Kami", href: "/contact" },
];
---

<footer class="bg-civil-primary text-white border-t-4 border-civil-secondary mt-auto">
  
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:py-16 lg:px-8">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      
      <div class="space-y-8 xl:col-span-1">
        <a href="/" class="flex flex-col group">
           <span class="text-2xl font-black text-white tracking-tighter uppercase">
             Pusat Alat Lab Sipil
           </span>
           <span class="text-xs font-bold text-civil-secondary tracking-[0.2em] uppercase mt-1">
             by CV. Sawarga Teknik
           </span>
        </a>
        <p class="text-sm leading-6 text-gray-300 max-w-xs">
          Distributor resmi dan produsen alat uji laboratorium teknik sipil. Melayani pengiriman ke seluruh Indonesia dengan standar garansi dan kalibrasi KAN.
        </p>
        
        <div class="space-y-3 text-sm text-gray-300">
          <div class="flex items-start gap-3">
            <svg class="h-6 w-6 text-civil-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>{SITE_CONFIG.address}</span>
          </div>
          <div class="flex items-center gap-3">
             <svg class="h-6 w-6 text-civil-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
             <a href={`https://wa.me/${SITE_CONFIG.whatsapp}`} class="hover:text-white hover:underline decoration-civil-secondary underline-offset-4 transition-all">
                +62 812-2345-6789 (WhatsApp)
             </a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="h-6 w-6 text-civil-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href={`mailto:${SITE_CONFIG.email}`} class="hover:text-white hover:underline decoration-civil-secondary underline-offset-4 transition-all">
                {SITE_CONFIG.email}
            </a>
          </div>
        </div>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 xl:col-span-2 xl:mt-0">
        
        <div>
          <h3 class="text-sm font-black uppercase tracking-wider text-civil-secondary border-b border-gray-700 pb-2 mb-4">
            Kategori Produk
          </h3>
          <ul role="list" class="space-y-3">
            {categories.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-gray-400 hover:text-white hover:translate-x-1 transition-transform inline-block">
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-black uppercase tracking-wider text-civil-secondary border-b border-gray-700 pb-2 mb-4">
            Perusahaan
          </h3>
          <ul role="list" class="space-y-3">
            {quickLinks.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-gray-400 hover:text-white hover:translate-x-1 transition-transform inline-block">
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="flex flex-col justify-start space-y-4">
           <h3 class="text-sm font-black uppercase tracking-wider text-civil-secondary border-b border-gray-700 pb-2 mb-4">
             Butuh Penawaran Cepat?
            </h3>
            <p class="text-xs text-gray-400 mb-2">
              Kami melayani pembuatan surat dukungan lelang dan faktur pajak (PPN).
            </p>
            
            <a href={getWALink("Halo, saya ingin konsultasi spesifikasi alat lab sipil.")} target="_blank" class="flex w-full items-center justify-center bg-civil-secondary px-4 py-3 text-sm font-black uppercase text-civil-primary border-2 border-transparent shadow-[4px_4px_0px_0px_rgba(255,255,255,0.2)] hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all">
               Chat Sales Sekarang
            </a>

            <button onclick="window.dispatchEvent(new CustomEvent('open-quote'))" class="flex w-full items-center justify-center bg-transparent border-2 border-gray-600 px-4 py-3 text-sm font-bold uppercase text-gray-300 hover:border-white hover:text-white transition-all">
               Formulir RFQ
            </button>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-gray-800 bg-civil-dark py-6">
    <div class="mx-auto max-w-7xl px-4 flex flex-col md:flex-row items-center justify-between gap-4 sm:px-6 lg:px-8">
      <p class="text-xs text-gray-500 text-center md:text-left">
        &copy; {currentYear} CV. Sawarga Teknik. All rights reserved. <br class="md:hidden">
        <span class="hidden md:inline"> | </span> 
        <a href="/privacy" class="hover:text-gray-300 underline">Privacy Policy</a>
      </p>
      
      <div class="flex space-x-6 opacity-50 hover:opacity-100 transition-opacity">
        <a href="#" class="text-gray-400 hover:text-white">
          <span class="sr-only">Facebook</span>
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
        </a>
        <a href="#" class="text-gray-400 hover:text-white">
          <span class="sr-only">Instagram</span>
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.468 2.37c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.821-.059.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.059-3.821-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>